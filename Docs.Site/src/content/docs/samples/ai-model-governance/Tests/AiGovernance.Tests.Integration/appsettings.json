{
  "Persistence": {
    "Provider": "InMemory"
  },
  "OpenTelemetry": {
    "ServiceName": "AiGovernance.Test",
    "ServiceNamespace": "AiGovernance",
    "CollectorEndpoint": "http://localhost:18889",
    "CollectorProtocol": "Grpc",
    "SamplingRate": 1.0,
    "EnablePrometheusExporter": false
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "WriteTo": []
  }
}
