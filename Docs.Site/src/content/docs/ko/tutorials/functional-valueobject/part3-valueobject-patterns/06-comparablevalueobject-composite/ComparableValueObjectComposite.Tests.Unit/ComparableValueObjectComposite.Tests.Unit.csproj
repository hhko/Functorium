    <IsTestProject>true</IsTestProject>
    <!-- Windows MAX_PATH(260) 회피: 어셈블리 이름 단축 (.exe 파일명만 영향) -->
    <AssemblyName>CmpVO.Composite.Tests.Unit</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="LanguageExt.Core" />
