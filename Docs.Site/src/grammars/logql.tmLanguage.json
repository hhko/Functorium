{
  "name": "logql",
  "scopeName": "source.logql",
  "patterns": [
    { "match": "#.*$", "name": "comment.line.number-sign.logql" },
    {
      "match": "\\b(count_over_time|rate|bytes_rate|bytes_over_time|sum|avg|min|max|stddev|stdvar|count|topk|bottomk|quantile_over_time|first_over_time|last_over_time|absent_over_time|sum_over_time|avg_over_time|min_over_time|max_over_time|unwrap|label_replace|vector|sort|sort_desc)\\b",
      "name": "entity.name.function.logql"
    },
    {
      "match": "\\b(by|without|bool|on|ignoring|group_left|group_right|offset)\\b",
      "name": "keyword.operator.word.logql"
    },
    {
      "match": "\\b(and|or|unless)\\b",
      "name": "keyword.operator.logical.logql"
    },
    {
      "match": "\\|=|!=|\\|~|!~|[!=><]=?|==",
      "name": "keyword.operator.comparison.logql"
    },
    { "match": "\\|", "name": "keyword.operator.pipe.logql" },
    {
      "match": "\\b(line_format|label_format|json|logfmt|regexp|pattern|unpack|decolorize|drop|keep)\\b",
      "name": "support.function.parser.logql"
    },
    {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.logql",
      "patterns": [{ "match": "\\\\.", "name": "constant.character.escape.logql" }]
    },
    {
      "begin": "`",
      "end": "`",
      "name": "string.quoted.backtick.logql"
    },
    { "match": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b", "name": "constant.numeric.logql" },
    {
      "begin": "\\{",
      "end": "\\}",
      "name": "meta.stream-selector.logql",
      "patterns": [
        { "match": "[a-zA-Z_][a-zA-Z0-9_]*", "name": "entity.other.attribute-name.logql" },
        { "match": "[!=~!><]=?", "name": "keyword.operator.comparison.logql" },
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.logql",
          "patterns": [{ "match": "\\\\.", "name": "constant.character.escape.logql" }]
        }
      ]
    }
  ]
}
