{
  "extraKnownMarketplaces": {
    "functorium-develop": {
      "source": {
        "source": "directory",
        "path": "./.claude/plugins/functorium-develop"
      }
    }
  },
  "enabledPlugins": {
    "functorium-develop": true
  },
  "permissions": {
    "allow": [
      "Bash(dotnet build:*)",
      "Bash(dotnet test:*)",
      "Bash(pwsh -File ./Build-VerifyAccept.ps1)",
      "Bash(git add:*)",
      "Bash(git commit:*)"
    ],
    "deny": [],
    "ask": []
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
