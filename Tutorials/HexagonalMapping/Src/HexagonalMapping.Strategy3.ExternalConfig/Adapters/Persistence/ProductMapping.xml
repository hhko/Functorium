<?xml version="1.0" encoding="utf-8"?>
<!--
  External Configuration: ORM 매핑을 XML로 정의합니다.

  이 방식을 사용하면 Domain Core의 Product 클래스에
  기술 어노테이션을 추가하지 않고도 ORM을 사용할 수 있습니다.

  실제로 이 방식은:
  - Hibernate (Java): hbm.xml 파일 지원
  - NHibernate (.NET): hbm.xml 파일 지원
  - Entity Framework: Fluent API로 대체 가능

  단점:
  - 코드와 매핑의 분리로 인한 혼란
  - IDE 지원 부족
  - 타입 안정성 감소
-->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2">

  <class name="HexagonalMapping.Domain.Entities.Product" table="products">

    <!-- Primary Key -->
    <id name="Id" column="id" type="Guid">
      <generator class="assigned"/>
    </id>

    <!-- Properties -->
    <property name="Name" column="name" type="String" length="200" not-null="true"/>

    <!-- Component: Money Value Object -->
    <component name="Price" class="HexagonalMapping.Domain.Entities.Money">
      <property name="Amount" column="price" type="Decimal"/>
      <property name="Currency" column="currency" type="String" length="3"/>
    </component>

  </class>

</hibernate-mapping>
